# Django settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF: comma-separated origins (e.g. https://kyc-service-au1k.onrender.com). Required for POST/HTTPS on Render.
# CSRF_TRUSTED_ORIGINS=https://kyc-service-au1k.onrender.com

# Database (optional). If not set or sqlite, uses db.sqlite3.
# For Neon PostgreSQL (Docker/Render) set DATABASE_URL so data and admin user persist.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# Backblaze B2 (S3-compatible) – optional. If set, media files (KYC IDs) are stored in B2 (private bucket, signed URLs).
# Never commit real keys; use env vars only (e.g. Render dashboard → Environment).
AWS_ACCESS_KEY_ID=your_b2_application_key_id
AWS_SECRET_ACCESS_KEY=your_b2_application_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_ENDPOINT_URL=https://s3.eu-central-003.backblazeb2.com
